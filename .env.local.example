# Label Studio Configuration
#
# JWT Activation Token (JWT Refresh Token) - 推荐使用
# =======================================================
# 这是 Label Studio 提供的 JWT activation token（也叫 refresh token）
#
# 获取方法：
# 1. 启动 Label Studio: label-studio start
# 2. 打开浏览器: http://localhost:8080
# 3. 登录账户
# 4. 点击右上角头像 -> Account & Settings
# 5. 找到 "Access Token" 或 "API Token" 区域
# 6. 复制 JWT token（以 "eyJ" 开头）
#
# ⚠️ 重要：Token 必须以 "eyJ" 开头（这是 JWT token 的标识）
#
# 工作原理：
# - 应用会自动调用 /api/token/refresh/ API
# - 使用 refresh token 获取 access token
# - Access token 会自动保存和刷新
#
# 留空 VITE_LABEL_STUDIO_TOKEN，让应用自动获取 access token

VITE_LABEL_STUDIO_URL=http://localhost:8080
VITE_LABEL_STUDIO_TOKEN=
VITE_LABEL_STUDIO_REFRESH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoicmVmcmVzaCIsImV4cCI6ODA3OTk5MzEyMywiaWF0IjoxNzcyNzkzMTIzLCJqdGkiOiI2MzE5YjRiOTIyOWI0Y2QyYjdhMTdhYTk1YTVhMjY0OCIsInVzZXJfaWQiOiIxIn0.w6DIwJ_XghNTs3fh0r_4JmpkPss76HC-2OFOfYp0dRA

VITE_PROJECT_ID=1

# 📝 注意：
# - 只需提供 VITE_LABEL_STUDIO_REFRESH_TOKEN（JWT activation token）
# - VITE_LABEL_STUDIO_TOKEN 留空即可
# - 应用会自动通过 refresh token 获取并管理 access token
